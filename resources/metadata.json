{
  "title": "Geonomia",
  "description": "Geonomia is a web application for exploring and analyzing biodiversity occurrence data, with a focus on collecting events and collectors. It provides tools for clustering occurrences, reconciling collector names, and visualizing data on maps.",
  "databases": {
    "geonomia": {
      "tables": {
        "reconcile_rb_rn_yr": {
          "description": "Open Refine compatible reconciliation backend for collecting event (collector family name, year, record number)",
          "plugins": {
            "datasette-reconcile": {
              "id_field": "gbifid",
              "name_field": "reconciliation_backend_key",
              "type_default": [
                {
                  "id": "collectingEvent",
                  "name": "CollectingEvent"
                }
              ],
              "max_limit": 5,
              "service_name": "Collecting event reconciliation",
              "view_url": "https://gbif.org/occurrence/{{id}}"
            }
          }
        },
        "cluster": {
          "columns": {
            "cluster_num_id": {
              "link": "/cluster/{value}"
            }
          }
        },
        "occ": {
          "columns": {
            "cluster_num_id": {
              "link": "/cluster/{value}"
            },
            "gbifID": {
              "link": "https://gbif.org/occurrence/{value}"
            }
          },
          "plugins": {
            "datasette-cluster-map": {
              "latitude_column": "decimalLatitude",
              "longitude_column": "decimalLongitude",
              "default_bounds": [
                [0.77, 100.09],
                [6.93, 119.18]
              ]
            }
          }
        }
      }
    }
  }
}